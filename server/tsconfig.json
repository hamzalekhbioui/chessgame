{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "declaration": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@chessgame/shared": ["../shared/src/types"]
    }
  },
  "include": ["src", "../shared/src"]
}
